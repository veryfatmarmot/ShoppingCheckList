{
  "expo": {
    "name": "Refillio",
    "slug": "shopping-check-list",
    "version": "0.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#2b2b2b",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2b2b2b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.marmot.shoppingchecklist"
    },
    "android": {
      "package": "dev.marmot.shoppingchecklist",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#30b348"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "./plugins/withReleaseSigning"
    ],
    "scheme": ["shoppingchecklist", "dev.marmot.shoppingchecklist"]
  }
}
