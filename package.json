{
  "name": "shopping-check-list",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --pool=threads",
    "mobile:start": "npm run start --workspace @shopping-check-list/mobile",
    "mobile:android": "npm run android --workspace @shopping-check-list/mobile",
    "mobile:web": "npm run web --workspace @shopping-check-list/mobile",
    "firebase:rules": "npx firebase-tools@latest deploy --only firestore:rules",
    "firebase:indexes": "npx firebase-tools@latest deploy --only firestore:indexes",
    "firebase:firestore": "npx firebase-tools@latest deploy --only firestore"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.4"
  },
  "allowScripts": {
    "@firebase/util@1.15.1": true,
    "esbuild@0.28.1": true,
    "protobufjs@7.6.5": true
  }
}
