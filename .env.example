# Copy this file to apps/mobile/.env and fill in the values from your Firebase
# project and Google OAuth clients. Expo reads env only from the app directory
# (apps/mobile/.env), not the repo root. All EXPO_PUBLIC_* values are embedded
# in the client bundle (they are client config, not server secrets).

# --- Firebase (Project settings → General → Your apps → Web app config) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Optional (Analytics); leave blank if unused.
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Google OAuth client IDs (Google Cloud → APIs & Services → Credentials) ---
# Required for Google Sign-In. Web is used by Expo Web; Android by the
# dev-client build. iOS is optional until iOS is set up.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
